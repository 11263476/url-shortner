{
  "namespace": "com.linkforge.analytics",
  "type": "record",
  "name": "UrlClicked",
  "fields": [
    {"name": "event_id", "type": ["null", "string"], "default": null},
{"name": "short_code", "type": "string"},
    {"name": "original_url", "type": "string"},
    {"name": "user_agent", "type": ["null", "string"], "default": null},
    {"name": "referer", "type": ["null", "string"], "default": null},
    {"name": "ip_address", "type": ["null", "string"], "default": null},
    {"name": "clicked_at", "type": {"type": "string", "logicalType": "datetime"}},
    {"name": "workspace_id", "type": ["null", "int"], "default": null},
    {"name": "country", "type": ["null", "string"], "default": null},
    {"name": "city", "type": ["null", "string"], "default": null},
    {"name": "device_type", "type": ["null", "string"], "default": null},
    {"name": "browser", "type": ["null", "string"], "default": null},
    {"name": "os", "type": ["null", "string"], "default": null}
  ]
}
